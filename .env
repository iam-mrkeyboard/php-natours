#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# logger.threshold = 4

# JWT Configuration
JWT_SECRET = your_super_secret_key_123

# Stripe Configuration
STRIPE_SECRET_KEY = sk_test_your_key_here
STRIPE_PUBLIC_KEY = pk_test_your_key_here
